# MarketMind Live Environment (.env.live.example)
# Copy to .env and fill in your own values. Do NOT commit real secrets.

APP_ENV=production
LOG_LEVEL=INFO

# Database (example Postgres URL; replace accordingly)
DB_URL=postgresql+psycopg://username:password@db-host:5432/marketmind
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
WORKER_CONCURRENCY=4
TASK_TIMEOUT=300

# Feature flags
SIMULATION_ENABLED=false
PRICING_ENABLED=true
INGESTION_ENABLED=true
ORDERS_ENABLED=true

# JWT/Auth
SECRET_KEY=change-this-strong-random-secret

# Amazon SP-API (Live)
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_SP_API_ROLE_ARN=arn:aws:iam::976193232373:role/SPAPIRole-NA
AMAZON_SP_API_REGION=us-east-1
AMAZON_SP_API_MARKETPLACE_IDS=ATVPDKIKX0DER
AMAZON_MODE=LIVE
AMAZON_IMPL=premade

# AWS credentials that can AssumeRole into SPAPIRole-NA
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# CJ Dropshipping
CJ_API_KEY=
CJ_WEBSITE_ID=

# Google Sheets
GOOGLE_APPLICATION_CREDENTIALS=/secure/path/to/service-account.json
SHEETS_GOVERNANCE_SPREADSHEET_ID=
GSHEETS_LEDGER_ID=

# eBay (Live - optional)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_USER_TOKEN=
EBAY_MODE=LIVE
