# MarketMind Autopilot environment template
# Copy this file to .env locally. Do not commit real secrets.
# This file contains PLACEHOLDER NAMES ONLY. Never paste real keys here.
# See docs/API_KEYS_AND_CREDENTIALS.md for how to retrieve each value safely.

# Runtime
MARKETMIND_ENV=development
MARKETMIND_DATABASE_URL=sqlite:///data/marketmind.db
MARKETMIND_LOG_DIR=logs
MARKETMIND_DEFAULT_CURRENCY=USD

# Safety defaults
MARKETMIND_MAX_DAILY_AD_SPEND=0
MARKETMIND_MAX_PER_NICHE_TEST_BUDGET=0
MARKETMIND_MAX_SAMPLE_ORDER_BUDGET=0
MARKETMIND_ENABLE_LIVE_WRITES=false
MARKETMIND_REQUIRE_APPROVAL_FOR_HIGH_RISK=true
MARKETMIND_BLOCK_CRITICAL_ACTIONS=true

# --- Stripe (sandbox/test first; prefer RESTRICTED keys over the unrestricted secret key) ---
# Live keys are not needed until approval-gated payment actions exist.
STRIPE_PUBLISHABLE_KEY=
STRIPE_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
MARKETMIND_STRIPE_DRY_RUN=true

# --- Shopify (development store first; start read-only) ---
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-07
MARKETMIND_SHOPIFY_READ_ONLY=true

# --- eBay (Developer Program SANDBOX first; OAuth tokens + scopes) ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_ENVIRONMENT=sandbox

# --- Amazon SP-API (later stage; requires developer/app registration + auth workflow) ---
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_SP_API_REGION=na

# --- Ad platforms (import/read-only first; no ad spend without approval gates) ---
META_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
MARKETMIND_ADS_READ_ONLY=true

# --- GitHub / Codex orchestration ---
GITHUB_TOKEN=
MARKETMIND_CODEX_TASK_REPO=AidanDCM/marketmind.site

# --- Supplier APIs ---
SUPPLIER_API_KEY=
SUPPLIER_API_BASE_URL=

# Notes
# 1. Never commit real keys; .env is gitignored.
# 2. Start integrations sandbox-first, read-only-first, least-privilege-first.
# 3. Prefer restricted/scoped keys over unrestricted secret keys.
# 4. Separate sandbox vs production and read-only vs write credentials.
# 5. Live writes require explicit approval-policy support (see APPROVAL_POLICY.md).
# 6. Any key-check command must validate presence/format WITHOUT printing values.
