# ========================
# Core Configuration
# ========================
APP_ENV=development  # development, staging, production
CONFIG_DEBUG=0  # Set to 1 for debug logging

# ========================
# Console Configuration
# ========================
NEXT_PUBLIC_API_URL=http://localhost:8001  # API URL for Next.js console

# ========================
# Database
# ========================
DB_URL=postgresql+psycopg2://postgres:postgres@db:5432/hive
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# For local development with SQLite:
# DB_URL=sqlite:///./dev.db

# ========================
# Redis
# ========================
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=10

# ========================
# AWS Configuration / S3
# ========================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=marketmind-dev
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# AWS Secrets Manager (production only)
# CONFIG_SECRETS_MANAGER=marketmind/production

# ========================
# Amazon SP-API (Selling Partner API)
# ========================
# LWA client credentials (from Seller Central Developer Console)
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
# Long-lived token obtained after seller consents your app
AMAZON_SP_API_REFRESH_TOKEN=
# IAM Role used for SP-API (e.g., arn:aws:iam::123:role/SPAPIRole-NA)
AMAZON_SP_API_ROLE_ARN=
# AWS region used for SP-API (e.g., us-east-1 for NA)
AMAZON_SP_API_REGION=us-east-1
# Comma-separated marketplace IDs (US: ATVPDKIKX0DER)
AMAZON_SP_API_MARKETPLACE_IDS=ATVPDKIKX0DER
# Mode can remain SANDBOX for non-live testing
AMAZON_MODE=SANDBOX  # SANDBOX or LIVE
AMAZON_IMPL=premade  # premade or native

# ========================
# eBay API
# ========================
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_REDIRECT_URI=
EBAY_MODE=SANDBOX  # SANDBOX or LIVE
EBAY_USER_TOKEN=

# ========================
# Walmart API
# ========================
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
WALMART_MODE=DRYRUN  # DRYRUN or LIVE

# ========================
# Commission Junction (CJ)
# ========================
CJ_API_KEY=
CJ_WEBSITE_ID=

# ========================
# Google Sheets
# ========================
# Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Google OAuth (if using user-based auth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Test spreadsheet ID for health checks
GSHEETS_LEDGER_ID=
# Target governance spreadsheet for ops logs (optional)
SHEETS_GOVERNANCE_SPREADSHEET_ID=

# ========================
# Shopify
# ========================
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=

# ========================
# AutoDS
# ========================
AUTODS_API_KEY=
AUTODS_TOKEN=

# ========================
# Feature Flags
# ========================
# Central flags consumed by packages.shared.config.flags
SIMULATION_ENABLED=true
PRICING_ENABLED=true
INGESTION_ENABLED=true
ORDERS_ENABLED=true

# ========================
# Logging
# ========================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text

# ========================
# Performance
# ========================
WORKER_CONCURRENCY=4
TASK_TIMEOUT=300  # seconds

# ========================
# Security
# ========================
# Secret key for cryptographic operations
SECRET_KEY=change-me-in-production
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Default admin (dev only)
AUTH_FIRST_SUPERUSER=admin@example.com
AUTH_FIRST_SUPERUSER_PASSWORD=changeme

# ========================
# Monitoring
# ========================
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# ========================
# External Services
# ========================
KEEPA_API_KEY=

# ========================
# Development Settings
# ========================
# Enable debug mode (do not use in production!)
DEBUG=1
# Allow all hosts in development
ALLOW_ALL_HOSTS=1

# ========================
# Console (Dashboard)
# ========================
# Point the dashboard to the local API (override per environment)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
# Disable auth in local single-tenant mode (dashboard will not require login)
NEXT_PUBLIC_AUTH_DISABLED=true
