# Console environment (local, single-team)
# Point to your running API URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001

# Disable auth for local single-team usage
NEXT_PUBLIC_AUTH_DISABLED=true

# Allow onboarding to be accessed without login
NEXT_PUBLIC_ONBOARDING_PUBLIC=true

# Optional: provide an API token if you enable auth later
# NEXT_PUBLIC_API_TOKEN=
