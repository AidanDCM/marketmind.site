# ========================
# MarketMind Production Configuration
# ========================
APP_ENV=production
CONFIG_DEBUG=0

# ========================
# Security (CRITICAL - CHANGE ALL DEFAULTS)
# ========================
# Generate strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY_32_CHARS_MIN
# Comma-separated production domains
TRUSTED_HOSTS=api.marketmind.ai,marketmind.ai
CORS_ORIGINS=https://app.marketmind.ai,https://marketmind.ai

# ========================
# Database (Production PostgreSQL)
# ========================
DB_URL=postgresql+psycopg2://username:password@prod-db-host:5432/marketmind_prod
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# ========================
# Redis (Production Cluster)
# ========================
REDIS_URL=redis://prod-redis-host:6379/0
REDIS_POOL_SIZE=20

# ========================
# Observability & Monitoring
# ========================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
WORKER_METRICS_PORT=9091

# ========================
# Rate Limiting & Security
# ========================
# Redis URL for rate limiting (can be same as main Redis)
SLOWAPI_REDIS_URL=redis://prod-redis-host:6379/1

# ========================
# Production Feature Flags
# ========================
SIMULATION_ENABLED=false
PRICING_ENABLED=true
INGESTION_ENABLED=true
ORDERS_ENABLED=true
DEBUG=0
ALLOW_ALL_HOSTS=0

# ========================
# AWS Production
# ========================
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=marketmind-prod
S3_REGION=us-east-1

# AWS Secrets Manager for sensitive configs
CONFIG_SECRETS_MANAGER=marketmind/production

# ========================
# Amazon SP-API (LIVE)
# ========================
AMAZON_SP_API_CLIENT_ID=amzn1.application-oa2-client...
AMAZON_SP_API_CLIENT_SECRET=...
AMAZON_SP_API_REFRESH_TOKEN=Atzr|...
AMAZON_SP_API_ROLE_ARN=arn:aws:iam::123456789:role/SPAPIRole-NA
AMAZON_SP_API_REGION=us-east-1
AMAZON_SP_API_MARKETPLACE_IDS=ATVPDKIKX0DER
AMAZON_MODE=LIVE
AMAZON_IMPL=premade

# ========================
# eBay API (LIVE)
# ========================
EBAY_APP_ID=...
EBAY_CERT_ID=...
EBAY_DEV_ID=...
EBAY_REDIRECT_URI=https://api.marketmind.ai/auth/ebay/callback
EBAY_MODE=LIVE
EBAY_USER_TOKEN=...

# ========================
# Walmart API (LIVE)
# ========================
WALMART_CLIENT_ID=...
WALMART_CLIENT_SECRET=...
WALMART_MODE=LIVE

# ========================
# Commission Junction
# ========================
CJ_API_KEY=...
CJ_WEBSITE_ID=...

# ========================
# Google Services
# ========================
# Use service account in production
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json
GSHEETS_LEDGER_ID=...
SHEETS_GOVERNANCE_SPREADSHEET_ID=...

# ========================
# Shopify
# ========================
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_...

# ========================
# AutoDS
# ========================
AUTODS_API_KEY=...
AUTODS_TOKEN=...

# ========================
# Performance & Scaling
# ========================
WORKER_CONCURRENCY=8
TASK_TIMEOUT=600
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========================
# External Services
# ========================
KEEPA_API_KEY=...
NEW_RELIC_LICENSE_KEY=...

# ========================
# Container Orchestration
# ========================
# Health check endpoints
HEALTH_CHECK_PATH=/health/summary
API_PORT=8001
WORKER_METRICS_PORT=9091

# ========================
# TLS & HTTPS
# ========================
# Ensure all traffic uses HTTPS in production
FORCE_HTTPS=true
SECURE_SSL_REDIRECT=true
